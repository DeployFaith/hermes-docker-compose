# =============================================================================
# Hermes Agent - Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# AT LEAST ONE LLM PROVIDER KEY IS REQUIRED
# The agent cannot function without access to a language model.
# Nous Portal (nous.ai) is recommended as it provides access to frontier models.
#
# Lines starting with hash are comments. Empty values are ignored.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. LLM PROVIDER (at least one required)
# -----------------------------------------------------------------------------
# Recommended: Nous Portal (nous.ai) -- Nous Research's own inference API
NOUS_API_KEY=***

# Alternative: OpenRouter (openrouter.ai/keys) -- access 100+ models with one key
OPENROUTER_API_KEY=***

# Alternative: Anthropic direct (console.anthropic.com)
ANTHROPIC_API_KEY=***

# Alternative: Google AI (aistudio.google.com/apikey)
GOOGLE_API_KEY=***
GEMINI_API_KEY=***

# Alternative: Ollama (local or cloud, ollama.com/settings)
OLLAMA_API_KEY=***


# -----------------------------------------------------------------------------
# 2. MESSAGING PLATFORMS (optional -- enable one or more)
# -----------------------------------------------------------------------------
# Telegram (t.me/BotFather)
TELEGRAM_BOT_TOKEN=***
# Comma-separated user IDs allowed to interact
TELEGRAM_ALLOWED_USERS=
# Channel/group ID for proactive messages
TELEGRAM_HOME_CHANNEL=

# Discord (discord.com/developers/applications)
DISCORD_BOT_TOKEN=***
# Comma-separated user IDs allowed to interact
DISCORD_ALLOWED_USERS=

# Slack (api.slack.com/apps)
SLACK_BOT_TOKEN=***
SLACK_APP_TOKEN=***
# Comma-separated user IDs allowed to interact
SLACK_ALLOWED_USERS=


# -----------------------------------------------------------------------------
# 3. OPTIONAL TOOLS AND INTEGRATIONS
# -----------------------------------------------------------------------------
# Image generation via fal.ai (fal.ai/dashboard/keys)
FAL_KEY=CHANGEME

# Browser automation via Browserbase (browserbase.com)
BROWSERBASE_API_KEY=***

# GitHub integration (github.com/settings/tokens)
GITHUB_TOKEN=***


# -----------------------------------------------------------------------------
# 4. DOCKER COMPOSE SETTINGS
# -----------------------------------------------------------------------------
# Persistent data directory for agent memory, logs, etc. (default: ~/.hermes)
HERMES_DATA_DIR=

# Port for the Hermes API gateway (default: 8642)
GATEWAY_PORT=

# Port for the web dashboard (default: 9119)
DASHBOARD_PORT=
